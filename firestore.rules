rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Documento principal del usuario: nombre, correo, pareja, racha, etc.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Subcolecciones: debts, goals, diaryEntries.
      // Mismo dueño, mismas reglas — nadie más puede leer ni escribir aquí,
      // ni siquiera otro usuario autenticado de la app.
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
